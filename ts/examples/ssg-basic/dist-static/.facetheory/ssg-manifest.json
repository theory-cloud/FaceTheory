{
  "version": 1,
  "routePathPolicy": "normalized",
  "htmlOutputPolicy": "index-or-html",
  "trailingSlash": "always",
  "assetManifest": {
    "format": "vite",
    "path": ".vite/manifest.json"
  },
  "pages": [
    {
      "routePattern": "/",
      "path": "/",
      "file": "index.html",
      "status": 200,
      "contentType": "text/html; charset=utf-8"
    },
    {
      "routePattern": "/404",
      "path": "/404",
      "file": "404/index.html",
      "status": 404,
      "contentType": "text/html; charset=utf-8"
    },
    {
      "routePattern": "/about",
      "path": "/about",
      "file": "about/index.html",
      "status": 200,
      "contentType": "text/html; charset=utf-8"
    },
    {
      "routePattern": "/blog/{slug}",
      "path": "/blog/hello-ssg",
      "file": "blog/hello-ssg/index.html",
      "status": 200,
      "contentType": "text/html; charset=utf-8"
    },
    {
      "routePattern": "/blog/{slug}",
      "path": "/blog/route-params",
      "file": "blog/route-params/index.html",
      "status": 200,
      "contentType": "text/html; charset=utf-8"
    }
  ],
  "notFoundFile": "404.html"
}
