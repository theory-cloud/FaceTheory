    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/antd": {
      "types": "./dist/react/antd.d.ts",
      "import": "./dist/react/antd.js"
    },
    "./react/antd-emotion": {
      "types": "./dist/react/antd-emotion.d.ts",
      "import": "./dist/react/antd-emotion.js"
    },
    "./react/emotion": {
      "types": "./dist/react/emotion.d.ts",
      "import": "./dist/react/emotion.js"
    },
    "./react/stitch-tokens": {
      "types": "./dist/react/stitch-tokens/index.d.ts",
      "import": "./dist/react/stitch-tokens/index.js"
    },
    "./react/stitch-shell": {
      "types": "./dist/react/stitch-shell/index.d.ts",
      "import": "./dist/react/stitch-shell/index.js"
    },
    "./react/stitch-hosted-auth": {
      "types": "./dist/react/stitch-hosted-auth/index.d.ts",
