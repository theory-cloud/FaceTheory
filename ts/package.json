    },
    "./responsive-primitives": {
      "types": "./dist/responsive-primitives/index.d.ts",
      "import": "./dist/responsive-primitives/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./testing": {
