    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@theory-cloud/apptheory": "https://github.com/theory-cloud/AppTheory/releases/download/v1.16.1/theory-cloud-apptheory-1.16.1.tgz",
    "@theory-cloud/apptheory-cdk": "https://github.com/theory-cloud/AppTheory/releases/download/v1.16.1/theory-cloud-apptheory-cdk-1.16.1.tgz",
    "@theory-cloud/tabletheory-ts": "https://github.com/theory-cloud/TableTheory/releases/download/v2.0.2/theory-cloud-tabletheory-ts-2.0.2.tgz",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vue/server-renderer": "^3.5.34",
    "antd": "^6.4.3",
    "aws-cdk-lib": "2.261.0",
    "c8": "^11.0.0",
    "constructs": "10.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "svelte": "^5.55.9",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vue": "^3.5.34"
  },
  "overrides": {
    "@theory-cloud/apptheory": {
      "@theory-cloud/tabletheory-ts": "https://github.com/theory-cloud/TableTheory/releases/download/v2.0.2/theory-cloud-tabletheory-ts-2.0.2.tgz"
    }
  },
  "sideEffects": false
}
