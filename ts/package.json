{
  "name": "@theory-cloud/facetheory",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/antd": {
      "types": "./dist/react/antd.d.ts",
      "import": "./dist/react/antd.js"
    },
    "./react/emotion": {
      "types": "./dist/react/emotion.d.ts",
      "import": "./dist/react/emotion.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js"
    }
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "antd": ">=5",
    "@emotion/react": ">=11",
    "@emotion/cache": ">=11",
    "@emotion/server": ">=11",
    "vue": ">=3",
    "@vue/server-renderer": ">=3",
    "svelte": ">=4"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/cache": {
      "optional": true
    },
    "@emotion/server": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@vue/server-renderer": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:unit",
    "test:unit": "tsx test/run-unit.ts"
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@types/node": "^24.10.9",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vue/server-renderer": "^3.5.13",
    "antd": "^6.2.3",
    "eslint": "^8.57.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svelte": "^5.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.13"
  }
}
