{
  "name": "@theory-cloud/facetheory",
  "version": "0.3.0",
  "description": "AWS-first SSR, SSG, and blocking ISR runtime for Node.js with React, Vue, and Svelte adapters.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theory-cloud/FaceTheory.git",
    "directory": "ts"
  },
  "homepage": "https://github.com/theory-cloud/FaceTheory/tree/main/docs",
  "bugs": {
    "url": "https://github.com/theory-cloud/FaceTheory/issues"
  },
  "keywords": [
    "aws",
    "cloudfront",
    "isr",
    "lambda",
    "react",
    "ssg",
    "ssr",
    "svelte",
    "vue"
  ],
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./aws-s3": {
      "types": "./dist/aws-s3/index.d.ts",
      "import": "./dist/aws-s3/index.js"
    },
    "./apptheory": {
      "types": "./dist/apptheory/index.d.ts",
      "import": "./dist/apptheory/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/antd": {
      "types": "./dist/react/antd.d.ts",
      "import": "./dist/react/antd.js"
    },
    "./react/antd-emotion": {
      "types": "./dist/react/antd-emotion.d.ts",
      "import": "./dist/react/antd-emotion.js"
    },
    "./react/emotion": {
      "types": "./dist/react/emotion.d.ts",
      "import": "./dist/react/emotion.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js"
    },
    "./tabletheory": {
      "types": "./dist/tabletheory/index.d.ts",
      "import": "./dist/tabletheory/index.js"
    }
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "antd": ">=5",
    "@emotion/react": ">=11",
    "@emotion/cache": ">=11",
    "@emotion/server": ">=11",
    "vue": ">=3",
    "@vue/server-renderer": ">=3",
    "svelte": ">=4"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/cache": {
      "optional": true
    },
    "@emotion/server": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@vue/server-renderer": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:unit",
    "test:unit": "tsx test/run-unit.ts",
    "ssg": "tsx src/ssg-cli.ts",
    "example:ssg:build": "tsx examples/ssg-basic/build.ts",
    "example:ssg:serve": "tsx examples/ssg-basic/serve-static.ts",
    "example:buffered:serve": "tsx examples/react-ssr-buffered/node-server.ts",
    "example:streaming:serve": "tsx examples/react-ssr-streaming/node-server.ts",
    "example:vite:ssr:build": "vite build --config examples/vite-ssr-react/vite.config.ts && vite build --ssr src/entry-server.tsx --config examples/vite-ssr-react/vite.config.ts",
    "example:vite:ssr:serve": "tsx examples/vite-ssr-react/node-server.ts",
    "example:vite:vue:build": "vite build --config examples/vite-ssr-vue/vite.config.ts && vite build --ssr src/entry-server.ts --config examples/vite-ssr-vue/vite.config.ts",
    "example:vite:vue:serve": "tsx examples/vite-ssr-vue/node-server.ts",
    "example:vite:svelte:build": "vite build --config examples/vite-ssr-svelte/vite.config.ts && vite build --ssr src/entry-server.ts --config examples/vite-ssr-svelte/vite.config.ts",
    "example:vite:svelte:serve": "tsx examples/vite-ssr-svelte/node-server.ts",
    "example:vite:svelte:library:build": "vite build --config examples/vite-ssr-svelte-library/vite.config.ts && vite build --ssr src/entry-server.ts --config examples/vite-ssr-svelte-library/vite.config.ts",
    "example:vite:svelte:library:serve": "tsx examples/vite-ssr-svelte-library/node-server.ts"
  },
  "devDependencies": {
    "@theory-cloud/apptheory": "https://github.com/theory-cloud/AppTheory/releases/download/v0.19.2/theory-cloud-apptheory-0.19.2.tgz",
    "@theory-cloud/tabletheory-ts": "https://github.com/theory-cloud/TableTheory/releases/download/v1.5.2/theory-cloud-tabletheory-ts-1.5.2.tgz",
    "@aws-sdk/client-s3": "^3.1005.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@types/node": "^24.12.0",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vue/server-renderer": "^3.5.30",
    "antd": "^6.3.2",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svelte": "^5.53.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.30"
  },
  "overrides": {
    "@theory-cloud/apptheory": {
      "@theory-cloud/tabletheory-ts": "https://github.com/theory-cloud/TableTheory/releases/download/v1.5.2/theory-cloud-tabletheory-ts-1.5.2.tgz"
    }
  }
}
